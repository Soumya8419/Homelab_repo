version: "3.9"

services:


  dumbassets:
    container_name: dumbassets
    image: dumbwareio/dumbassets:latest
    restart: unless-stopped
    volumes:
      - /mnt/ssd/srv/dockerdata/dumbassets/data:/app/data

    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.dumbassets.rule=Host(`dumbassets.nucserver2.home.arpa`)"
      - "traefik.http.routers.dumbassets.entrypoints=web"
      - "traefik.http.services.dumbassets.loadbalancer.server.port=3000"
    networks:
      - traefik
networks:
  traefik:
    external: true
    name: traefik_web
